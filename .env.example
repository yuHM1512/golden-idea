# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/golden_idea
SQLALCHEMY_ECHO=False

# FastAPI
API_TITLE=Golden Idea Web App
API_VERSION=0.1.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# JWT (TODO: Enable when implementing password-based auth)
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=300
ALLOWED_EXTENSIONS=["jpg","jpeg","png","gif","mp4","avi","mov"]

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8015

# Approval page link used in email
APPROVAL_PAGE_URL=http://localhost:8015/pages/approvals

# Gmail email sending
SMTP_EMAIL=hachiba@hachibavn.com
